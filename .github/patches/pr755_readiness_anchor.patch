+    selected_tip_available: bool,
+    accepted_blocks: u64,
+    rejected_blocks: u64,
+) -> ReadinessCategory {
+    status_reasons(
+        if !chain_anchor_valid {
+            vec![
+                "neither physical genesis nor a validated compact-prune checkpoint anchors the chain"
