# Rust build output
/target/
**/*.rs.bk

# PulseDAG local runtime data
/data/
/logs/
/run/
/artifacts/

# Local env files
.env
.env.*
!.env.example

# Generated release/rehearsal evidence artifacts
# Keep curated Markdown evidence and summaries tracked; ignore bulky runtime/log output.
/evidence/**/logs/
/evidence/**/runtime/
/evidence/**/node-*/
/evidence/**/tmp/
/evidence/**/p2p-rehearsal/*/logs/
/evidence/**/p2p-rehearsal/*/runtime/
/evidence/**/p2p-rehearsal/*/node-*/
/evidence/**/p2p-rehearsal/*/summary.txt
/evidence/**/p2p-rehearsal/*/rehearsal-config.json
/evidence/**/*.log
/evidence/**/*.tmp

# Global temporary/runtime artifacts
*.log
*.tmp
*.bak
*.old
*.orig
*.swp
*.swo
*.zip
*.tar.gz
*~

# Editor and OS noise
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
