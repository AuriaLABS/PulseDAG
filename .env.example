# PulseDAG node environment example
# Copy to `.env` and adjust values for your environment.

# Profile defaults: dev | testnet | operator (alias: staging)
PULSEDAG_CONFIG_PROFILE=testnet

# Core node identity/network
PULSEDAG_CHAIN_ID=pulsedag-testnet
PULSEDAG_RPC_BIND=0.0.0.0:8080
PULSEDAG_ROCKSDB_PATH=./data/rocksdb

# P2P
PULSEDAG_P2P_ENABLED=true
PULSEDAG_P2P_MODE=libp2p
PULSEDAG_P2P_LISTEN=/ip4/0.0.0.0/tcp/30333
# Comma-separated multiaddr list
PULSEDAG_P2P_BOOTSTRAP=
PULSEDAG_P2P_MDNS=true
PULSEDAG_P2P_KADEMLIA=true

# Optional in-memory/simulated peer list (comma-separated)
PULSEDAG_SIMULATED_PEERS=

# Startup behavior
PULSEDAG_AUTO_REBUILD_ON_START=true
PULSEDAG_PERSIST_SNAPSHOT_ON_START=true

# Consensus / timing
PULSEDAG_TARGET_BLOCK_INTERVAL_SECS=60
PULSEDAG_DIFFICULTY_WINDOW=20
PULSEDAG_DIFFICULTY_USE_MEDIAN=false
PULSEDAG_MAX_FUTURE_DRIFT_SECS=120

# Snapshot / pruning
PULSEDAG_SNAPSHOT_AUTO_EVERY_BLOCKS=25
PULSEDAG_AUTO_PRUNE_ENABLED=true
PULSEDAG_AUTO_PRUNE_EVERY_BLOCKS=100
PULSEDAG_PRUNE_KEEP_RECENT_BLOCKS=500
PULSEDAG_PRUNE_REQUIRE_SNAPSHOT=true
